# Copy this file to .env and fill in real values. Never commit .env.
# See README.md "Quickstart" for how each of these is used.

# --- DataHub OSS connection ---
# Default values match `datahub docker quickstart` / this repo's docker-compose.yml.
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_FRONTEND_URL=http://localhost:9002
# Personal Access Token generated in DataHub UI (Settings > Access Tokens). Empty is fine
# for a fresh local quickstart, which is unauthenticated by default.
DATAHUB_GMS_TOKEN=

# Enables the mutation-capable MCP tools (add_tags, update_description, add_owners, ...).
# Sentinel's agents that need to write to DataHub require this set to true.
TOOLS_IS_MUTATION_ENABLED=true

# --- LLM (Anthropic) ---
# Required for Migration Copilot codegen and Metadata Enrichment drafting.
ANTHROPIC_API_KEY=
# No default model is hardcoded — check https://docs.claude.com for the current
# recommended model id and set it explicitly.
ANTHROPIC_MODEL=claude-opus-4-8

# --- GitHub (PR Impact Analysis + Migration Copilot) ---
# Fine-grained PAT with contents:write, pull_requests:write on the target repo(s).
GITHUB_TOKEN=

# --- Notifiers ---
SLACK_WEBHOOK_URL=
# Alternative to a webhook: a bot token with chat:write, used if set.
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#data-incidents

# --- Sentinel behavior ---
# Path to the incident severity rules config (see core/incident_engine.py).
SENTINEL_SEVERITY_RULES_PATH=config/severity_rules.yml
# Path to the quality checks config (see agents/quality_checker).
SENTINEL_QUALITY_CHECKS_PATH=quality_checks.yml
# Where the pending-metadata-proposal store lives (see core/proposal_engine.py).
SENTINEL_PROPOSALS_PATH=proposals.json
# Default lineage hop limit for blast-radius walks.
SENTINEL_LINEAGE_HOP_LIMIT=3
